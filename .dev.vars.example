# Copy to .dev.vars for local `wrangler dev`. NEVER commit .dev.vars.
# In production these are set via `wrangler secret put`.

OKTA_CLIENT_SECRET="replace_with_okta_app_client_secret"
GOOGLE_CLIENT_ID="replace_with_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="replace_with_google_oauth_client_secret"

# Generate with: openssl rand -hex 32
SESSION_SECRET="replace_with_64_hex_chars"

# Optional: override to "development" for local dev-mode mock auth
# (X-Mock-User-Email / X-Mock-User-Role headers bypass the cookie check).
ENVIRONMENT="development"
